Options -Indexes
Options +FollowSymLinks
RewriteEngine On

# ── HTTPS redirect ──────────────────────────────────────────────
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ── Block sensitive files ────────────────────────────────────────
<FilesMatch "\.(env|sql|log|sh|bak|ini)$">
  Order Allow,Deny
  Deny from all
</FilesMatch>

# Block direct access to includes and config
RewriteRule ^(includes|config)/.*$ - [F,L]

# ── Pretty payment URLs ───────────────────────────────────────────
# /pay/slug → /pay.php?slug=slug
RewriteRule ^pay/([a-z0-9\-]+)/?$ pay.php?slug=$1 [L,QSA]
# /receipt/code → /receipt.php?ref=code
RewriteRule ^receipt/([A-Z0-9\-]+)/?$ receipt.php?ref=$1 [L,QSA]

# ── Hide .php extension ──────────────────────────────────────────
# Excludes includes/config (already blocked above) AND webhook.php —
# external services like Nomba POST directly to webhook.php and will
# NOT follow redirects, so redirecting it here silently kills webhook
# delivery. Add any other externally-called endpoint here the same way.
RewriteCond %{REQUEST_URI} !^/(includes|config)/
RewriteCond %{REQUEST_URI} !^/webhook\.php$
RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(.*?)/?$ $1.php [L,QSA]

# ── Block config access ──────────────────────────────────────────
<Files "db.php">
  Order Allow,Deny
  Deny from all
</Files>

# ── Security headers ──────────────────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── PHP session security ──────────────────────────────────────────
<IfModule mod_php.c>
  php_value session.cookie_httponly 1
  php_value session.cookie_samesite "Strict"
  php_value session.use_strict_mode 1
</IfModule>

# ── Gzip compression ─────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# ── Browser caching for assets ────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# php -- BEGIN cPanel-generated handler, do not edit
# Set the "ea-php81" package as the default "PHP" programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php81 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit